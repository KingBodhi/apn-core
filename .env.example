# APN Core Server Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# SERVER SETTINGS
# =============================================================================
APN_HOST=0.0.0.0
APN_PORT=8000
APN_LOG_LEVEL=INFO
APN_DEBUG=false

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Comma-separated list of allowed CORS origins (use * only for development)
APN_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
APN_API_KEY=

# Rate limiting (requests per minute)
APN_RATE_LIMIT=60

# =============================================================================
# MESH NETWORKING
# =============================================================================
# NATS relay server for mesh networking
APN_NATS_RELAY=nats://nonlocal.info:4222

# Known peer nodes (comma-separated URLs)
APN_KNOWN_PEERS=https://dashboard.powerclubglobal.com,https://pythia.nonlocal.info

# =============================================================================
# BACKEND SERVICES
# =============================================================================
# Nora backend URL
APN_NORA_URL=http://127.0.0.1:3003

# =============================================================================
# DATABASE
# =============================================================================
# SQLite database path (relative to ~/.apn/)
APN_DATABASE_PATH=apn_core.db

# =============================================================================
# IDENTITY
# =============================================================================
# Node identity file path (relative to ~/.apn/)
APN_IDENTITY_FILE=node_identity.json

# =============================================================================
# CONTRIBUTION SETTINGS
# =============================================================================
APN_CONTRIBUTION_ENABLED=false
APN_CONTRIBUTION_RELAY=false
APN_CONTRIBUTION_COMPUTE=false
APN_CONTRIBUTION_STORAGE=false
APN_STORAGE_GB_ALLOCATED=10
APN_COMPUTE_CORES_ALLOCATED=1
APN_BANDWIDTH_LIMIT_MBPS=100
